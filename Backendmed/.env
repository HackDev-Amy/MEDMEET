# OTP Delivery Method
# Options: EMAIL (free), TWILIO (paid), AWS_SNS (paid)
OTP_DELIVERY=EMAIL

# Twilio Configuration (optional - if switching to SMS later)
# Get these from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS Configuration (optional - if switching to SMS later)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# OTP Configuration
OTP_VALIDITY_MINUTES=10
OTP_LENGTH=6
MAX_OTP_ATTEMPTS=3

# Email Configuration - REAL EMAIL SENDING
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=medmeet.noreply@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# Debug Mode
DEBUG=True
